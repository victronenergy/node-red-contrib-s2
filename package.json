{
  "name": "esbuild-node-red-experiment",
  "version": "0.1.0",
  "description": "Experimental package to test setting up a node-red contribution project with typescript support\"",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/my-node.ts --bundle --platform=node --target=node18 --outdir=dist --external:node-red && cp src/my-node.html dist/my-node.html",
    "test": "npm run jest"
  },
  "author": "chris@uber5.com",
  "license": "ISC",
  "node-red": {
    "nodes": {
      "my-node": "dist/my-node.js"
    }
  },
  "devDependencies": {
    "@types/node-red": "^1.3.5",
    "esbuild": "0.25.9",
    "node-red": "^4.1.0"
  }
}
