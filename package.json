{
  "name": "esbuild-node-red-experiment",
  "version": "0.1.0",
  "description": "Experimental package to test setting up a node-red contribution project with typescript support\"",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/* --bundle --platform=node --loader:.html=copy --loader:.ts=ts --target=node18 --outdir=dist --external:node-red",
    "dev": "esbuild --watch src/* --bundle --platform=node --loader:.html=copy --loader:.ts=ts --target=node18 --outdir=dist --external:node-red",
    "test": "jest"
  },
  "author": "chris@uber5.com",
  "license": "ISC",
  "node-red": {
    "nodes": {
      "my-node": "dist/my-node.js"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node-red": "^1.3.5",
    "esbuild": "0.25.9",
    "jest": "^30.1.3",
    "node-red": "^4.1.0",
    "ts-jest": "^29.4.1"
  }
}
